<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Assistive Device Exchange</title>

    <link rel="stylesheet" href="css/style.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar">
        <div class="logo">Ability hub</div>

        <ul class="nav-links">
            <li><a href="#home">Home</a></li>
            <li><a href="#devices">Browse Devices</a></li>
            <li><a href="#about">About</a></li>
            <li><a href="contact.html">Contact</a></li>
        </ul>

        <div class="nav-buttons">
            <a href="login.html" class="login-btn">Login</a>
            <a href="register.html" class="register-btn">Register</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero" id="home">
        <div class="hero-content">
            <h1>Find, Donate, or Exchange Assistive Devices Easily</h1>
            <p>Connecting patients, hospitals, charities, and donors in one platform.</p>

            <div class="hero-buttons">
                <a href="#devices"><button>Browse Devices</button></a>
                <a href="donor.html"><button class="secondary-btn">Donate Now</button></a>
            </div>
        </div>
    </section>

    <!-- Search -->
    <section class="search-section">
        <input type="text" placeholder="Search for assistive devices...">
        <button>Search</button>
    </section>

    <!-- Featured Devices -->
    <section class="devices-section" id="devices">
        <h2>Featured Devices</h2>

        <div class="devices-grid">

            <div class="device-card">
                <img src="images/wheelchair.jpg" alt="Wheelchair">
                <div class="device-info">
                    <h3>Wheelchair</h3>
                    <p>Used - Free</p>
                    <button>View Details</button>
                </div>
            </div>

            <div class="device-card">
                <img src="images/hearing.jpg" alt="Hearing Aid">
                <div class="device-info">
                    <h3>Hearing Aid</h3>
                    <p>New - $50</p>
                    <button>View Details</button>
                </div>
            </div>

            <div class="device-card">
                <img src="images/walker.jpg" alt="Walker">
                <div class="device-info">
                    <h3>Walker</h3>
                    <p>Used - Free</p>
                    <button>View Details</button>
                </div>
            </div>

        </div>
    </section>

    <!-- About Section -->
    <section class="about-section" id="about">
        <h2>About Ability Hub</h2>
        <p>
            Ability Hub is an assistive device exchange platform connecting patients,
            hospitals, charities, and donors in one place to make access to
            medical assistive devices easier and faster.
        </p>
    </section>

</body>

</html>
